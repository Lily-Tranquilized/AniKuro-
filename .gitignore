# .gitignore - AniKuro Backend

# Environment variables
.env
.env.local
.env.*.local

# Dependencies
node_modules/
package-lock.json
yarn.lock

# IDE and Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime
dist/
build/
.next/
out/

# Testing
coverage/
.nyc_output/

# OS
Thumbs.db
.DS_Store

# Temporary files
tmp/
temp/
*.tmp

# Build outputs
*.tsbuildinfo

# Optional npm cache
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# dotenv environment variables file
.env.test

# Mac files
.DS_Store
